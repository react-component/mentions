{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"],
      "@@/*": ["./.dumi/tmp/*"],
      "@rc-component/mentions": ["./src/index.ts"]
    },
    "strict": false,
    "module": "ESNext"
  },
  "include": [
    "global.d.ts",
    ".dumirc.ts",
    ".fatherrc.ts",
    "**/*.ts",
    "**/*.tsx"
  ]
}
